FROM python:3.12-slim
WORKDIR /app
COPY src/leadcollector.py .
RUN mkdir -p /data
RUN groupadd -r leadcol && useradd -r -g leadcol -d /app -s /sbin/nologin leadcol
RUN chown -R leadcol:leadcol /app /data
EXPOSE 8090
HEALTHCHECK --interval=10s --timeout=3s CMD python3 -c "import urllib.request; urllib.request.urlopen('http://localhost:8090/health')"
USER leadcol
CMD ["python3", "leadcollector.py"]
