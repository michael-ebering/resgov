# ResGov Environment Configuration
# Copy to .env and fill in your values

# --- Authentication ---
# [REQUIRED] Admin token — min. 32 chars. Generate with: openssl rand -hex 32
# Without this, the API will refuse to start.
RESGOV_ADMIN_TOKEN=

# [OPTIONAL] Set to "true" ONLY for local development (disables auth entirely)
# Default: false — Dev mode is NOT active by default
RESGOV_DEV_MODE=false

# Legacy: comma-separated API keys (migrated to DB on first start)
# Format: "key1:owner1,key2:owner2"
RESGOV_API_KEYS=

# --- Database ---
RESGOV_DB_PATH=/data/resgov.db

# [OPTIONAL] Fallback DB path if RESGOV_DB_PATH is not writable
# Without this, startup fails if default path is read-only
RESGOV_DB_FALLBACK_PATH=

# --- Server ---
RESGOV_HOST=0.0.0.0
RESGOV_PORT=8080

# --- CORS ---
# [OPTIONAL] Comma-separated allowed origins for self-hosted setups
# Default: restricted to resgov.silentops.cloud / api.resgov.silentops.cloud
# Example: RESGOV_CORS_ORIGINS=https://your-domain.com,https://dashboard.your-domain.com
RESGOV_CORS_ORIGINS=

# --- LLM Provider ---
# Choose: "openrouter" (default) or "github-copilot"
RESGOV_PROVIDER=openrouter

# --- OpenRouter (default provider) ---
RESGOV_UPSTREAM_URL=https://openrouter.ai/api/v1/chat/completions
RESGOV_UPSTREAM_API_KEY=

# --- GitHub Copilot (alternative provider) ---
# Set RESGOV_PROVIDER=github-copilot to activate
# Requires a GitHub OAuth token with copilot scope
GITHUB_COPILOT_TOKEN=

# --- Custom Price Table (optional) ---
# Override model pricing as JSON: {"model": {"input": 0.001, "output": 0.002}}
RESGOV_PRICE_TABLE=

# --- Dashboard ---
# Basic auth credentials
# Leave empty → auto-generated on startup (check logs for the password)
RESGOV_DASH_USER=admin
RESGOV_DASH_PASS=

# --- Security ---
# [OPTIONAL] Set to "true" if behind HTTPS reverse proxy (Traefik, Nginx)
# Default: false — startup warns if not set
RESGOV_BEHIND_HTTPS_PROXY=false

# --- Audit Log Retention ---
# [OPTIONAL] Days to keep audit log entries (0 = keep forever, default: 365)
RESGOV_AUDIT_RETENTION_DAYS=365

# --- Backup ---
RESGOV_BACKUP_DIR=/data/backups
RESGOV_BACKUP_RETENTION=7
