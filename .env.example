# ResGov Environment Configuration
# Copy to .env and fill in your values

# --- Authentication ---
# Comma-separated API keys (generate with: python -c "import secrets; print(secrets.token_hex(16))")
RESGOV_API_KEYS=

# Admin token for /admin/* endpoints
RESGOV_ADMIN_TOKEN=

# --- Database ---
RESGOV_DB_PATH=/data/resgov.db

# --- Server ---
RESGOV_HOST=0.0.0.0
RESGOV_PORT=8080

# --- CORS ---
# Comma-separated allowed origins (empty = allow all in dev)
RESGOV_CORS_ORIGINS=

# --- Webhooks ---
# URL for webhook notifications (budget exceeded, agent events)
RESGOV_WEBHOOK_URL=
RESGOV_WEBHOOK_SECRET=
